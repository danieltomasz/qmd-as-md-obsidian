tag-version-prefix = ""

# @codemirror/commands declares a peer of @codemirror/state ^6.6.0, but
# Obsidian pins @codemirror/state to exactly 6.5.0 — these packages are
# externalised in rollup.config.js, so the runtime uses Obsidian's copy
# and the version skew is harmless. eslint-plugin-obsidianmd's transitive
# plugins also peer-require an older eslint major. Accept both rather
# than fighting the tree on every install.
legacy-peer-deps = true
